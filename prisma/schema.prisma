generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRATIVO
  MEDICO
  PROFISSIONAL
}

enum OrganizationType {
  CLINICA
  PROFISSIONAL_GROUP
}

enum ReferralStatus {
  Encaminhado
  Agendado
  Atendido
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  emailVerified  DateTime?
  name           String
  image          String?
  passwordHash   String?
  role           UserRole      @default(PROFISSIONAL)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isAdmin        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  accounts       Account[]
  sessions       Session[]
  createdReferrals Referral[]  @relation("CreatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id               String              @id @default(cuid())
  name             String
  type             OrganizationType
  cnpj             String?
  address          String?
  phone            String?
  users            User[]
  referrals        Referral[]          @relation("ReferralClinic")
  referralsSent    Referral[]          @relation("ReferralOffice")
  professionalAccessesOutgoing ProfessionalAccess[] @relation("ProfessionalGroup")
  professionalAccessesIncoming ProfessionalAccess[] @relation("Clinic")
  createdAt        DateTime            @default(now())
}

model ProfessionalAccess {
  id                   String       @id @default(cuid())
  professionalGroupId  String
  professionalGroup    Organization @relation("ProfessionalGroup", fields: [professionalGroupId], references: [id], onDelete: Cascade)
  clinicId             String
  clinic               Organization @relation("Clinic", fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())

  @@unique([professionalGroupId, clinicId])
}

model CareNucleus {
  id          String                @id @default(cuid())
  name        String
  description String
  chargedPrice Decimal              @db.Decimal(10, 2)
  services    CareNucleusService[]
  referrals   Referral[]
  createdAt   DateTime              @default(now())
}

model CareNucleusService {
  id        String     @id @default(cuid())
  nucleusId String
  name      String
  basePrice Decimal    @db.Decimal(10, 2)
  nucleus   CareNucleus @relation(fields: [nucleusId], references: [id], onDelete: Cascade)
}

model Referral {
  id                  String             @id @default(cuid())
  patientName         String
  patientBirthDate    DateTime
  patientPhone        String
  patientDocument     String?
  systemicDiseases    String?
  clinicalNotes       String?
  clinicalSuspicion   String?
  status              ReferralStatus     @default(Encaminhado)
  doctor              String?
  appointmentDate     DateTime?
  specialistNotes     String?
  specialistConduct   String?
  nucleusId           String
  nucleus             CareNucleus        @relation(fields: [nucleusId], references: [id])
  nucleusSnapshotName String
  nucleusSnapshotPrice Decimal           @db.Decimal(10, 2)
  nucleusSnapshotServices Json?
  clinicId            String
  clinic              Organization       @relation("ReferralClinic", fields: [clinicId], references: [id], onDelete: Cascade)
  officeId            String
  office              Organization       @relation("ReferralOffice", fields: [officeId], references: [id], onDelete: Cascade)
  createdByUserId     String
  createdByUser       User               @relation("CreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  documents           ReferralDocument[]
  specialistFiles     ReferralAttachment[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ReferralDocument {
  id         String   @id @default(cuid())
  referralId String
  fileName   String
  url        String?
  createdAt  DateTime @default(now())
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
}

model ReferralAttachment {
  id         String   @id @default(cuid())
  referralId String
  fileName   String
  url        String?
  createdAt  DateTime @default(now())
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
}
